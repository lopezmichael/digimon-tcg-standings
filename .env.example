# Neon PostgreSQL Configuration
# Get your connection details from: https://console.neon.tech
NEON_HOST=your-project.us-east-2.aws.neon.tech
NEON_DATABASE=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=your_password_here

# Mapbox Configuration (for store map)
# Get your token from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Admin Authentication
# No env vars needed — first admin account is created via in-app bootstrap.
# On first launch, click the lock icon to create the super admin account.
# Additional admins are managed via the "Manage Admins" tab.

# Google Cloud Vision API (for OCR screenshot parsing)
# Get your key from: https://console.cloud.google.com/apis/credentials
# Requires: Cloud Vision API enabled, billing account linked (free tier: 1,000 images/month)
GOOGLE_CLOUD_VISION_API_KEY=your_api_key_here

# Sentry Error Tracking (optional - errors logged to console if not set)
# Create a project at https://sentry.io and get your DSN
SENTRY_DSN=

# Discord Webhooks (for in-app → Discord routing)
# Create webhooks in Discord Server Settings → Integrations → Webhooks
# One webhook per target Forum channel
DISCORD_WEBHOOK_SCENE_COORDINATION=
DISCORD_WEBHOOK_SCENE_REQUESTS=
# Tag ID for "New Request" in #scene-requests Forum (right-click tag → Copy ID with Developer Mode on)
DISCORD_TAG_NEW_REQUEST=
